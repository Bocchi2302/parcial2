{
  "info": {
    "name": "Parcial2 CRM - Full API",
    "description": "Coleccion completa para Auth + Clientes + Contactos + Oportunidades.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Usuario CRM\",\n  \"email\": \"usuario.crm@example.com\",\n  \"password\": \"Pass1234*\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login (save token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const token = json?.data?.token;",
                  "if (token) {",
                  "  pm.collectionVariables.set('token', token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@bookstore.com\",\n  \"password\": \"Admin123*\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Clientes",
      "item": [
        {
          "name": "Create Cliente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Empresa Demo\",\n  \"correo\": \"empresa.demo@example.com\",\n  \"telefono\": \"3001234567\",\n  \"direccion\": \"Calle 10 #20-30\",\n  \"usuarioAsignadoId\": {{usuarioAsignadoId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clientes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get All Clientes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/clientes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Cliente By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/clientes/{{clienteId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes",
                "{{clienteId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Cliente",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Empresa Demo Actualizada\",\n  \"correo\": \"empresa.demo.updated@example.com\",\n  \"telefono\": \"3009999999\",\n  \"direccion\": \"Avenida 50 #10-20\",\n  \"usuarioAsignadoId\": {{usuarioAsignadoId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clientes/{{clienteId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes",
                "{{clienteId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Cliente (ADMIN)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/clientes/{{clienteId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes",
                "{{clienteId}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Contactos",
      "item": [
        {
          "name": "Create Contacto for Cliente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Contacto Demo\",\n  \"correo\": \"contacto.demo@example.com\",\n  \"telefono\": \"3011111111\",\n  \"cargo\": \"Compras\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clientes/{{clienteId}}/contactos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes",
                "{{clienteId}}",
                "contactos"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Oportunidades",
      "item": [
        {
          "name": "Create Oportunidad for Cliente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Venta anual CRM\",\n  \"descripcion\": \"Propuesta de suscripcion anual\",\n  \"monto\": 15000.00,\n  \"etapa\": \"PROSPECCION\",\n  \"fechaCierreEstimada\": \"2026-12-31\",\n  \"creadoPorId\": {{creadoPorId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clientes/{{clienteId}}/oportunidades",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes",
                "{{clienteId}}",
                "oportunidades"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "clienteId",
      "value": "1"
    },
    {
      "key": "usuarioAsignadoId",
      "value": "1"
    },
    {
      "key": "creadoPorId",
      "value": "1"
    }
  ]
}
